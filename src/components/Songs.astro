---
const TITULO = Astro.props.titulo
const ARTISTA = Astro.props.artista
const IMAGEN = Astro.props.imagen
---
<div class="border border-solid border-black rounded-4xl p-6 w-full sm:w-fit flex flex-col gap-4 tarjeta-Cancion">
    <img src={IMAGEN} alt="" class="w-[320px]">
    <h3 class="font-bold text-lg">{TITULO}</h3>
    <div class="flex gap-3">
        <p>{ARTISTA}</p>
        <p>Duracion</p>
    </div>
</div>