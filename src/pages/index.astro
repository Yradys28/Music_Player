---
import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';

const titel = 'hola soy un titulo'
---

<Layout>
	<div class="flex flex-col items-center gap-16 p-20">
		<h1 class="text-3xl" id="titulo">{titel}</h1>
		<button class="bg-amber-700 px-4 py-2 rounded-4xl" id="button">si me presionas va a pasar algo</button>
	</div>
</Layout>

<script>
	const BUTTON = document.getElementById('button')
	const TITTLE = document.getElementById('titulo')

	BUTTON?.addEventListener('click', function(){
		TITTLE? TITTLE.innerHTML = 'VISCA BARCA' : null
		TITTLE?.classList.toggle('text-red-700')
	})
</script>
