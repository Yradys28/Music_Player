---
import Layout from "../layouts/Layout.astro";
import Songs from "../components/Songs.astro";
import axios from "axios"


const LIST_SERVER = await axios.get("https://api.institutoalfa.org/api/songs")

---

<Layout>
    <div class="w-full flex justify-center pt-6 bg-[#171021]">
        <div class=" w-[85%] bg-[#7f13ec] text-white py-2 px-8 rounded-4xl flex items-center gap-2">
            <img src="/images/play.png" alt="">
            <p>Play Now</p>
        </div>
    </div>
    <div class="pt-6 bg-[#171021] w-full flex flex-wrap justify-center items-center gap-6">
    <div class="flex flex-wrap justify-center gap-8">
        {
            LIST_SERVER.data.songs.map(function (valor : any) {
                return <Songs titulo={valor.title} artista={valor.author.name} imagen={valor.album.image.url} _id={valor._id}/>;
            })
        }
    </div>
</Layout>

<style></style>

<script></script>
